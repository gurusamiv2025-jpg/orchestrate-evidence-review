# Copy to .env and fill in. NEVER commit .env or paste keys into the chat transcript.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults shown). Override if your account exposes different IDs.
# ANTHROPIC_MODEL_OPUS=claude-opus-4-8
# ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
# ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# Optional tuning
# ORCH_MAX_WORKERS=4          # concurrent claims
# ORCH_MAX_IMAGE_EDGE=1280    # px; longest image edge after downscale (cost control)
# ORCH_CACHE_DIR=.orch_cache  # disk cache location (relative to code/)
